<mxfile>
  <diagram name="Inventory Flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- Menu -->
        <mxCell id="menu" value="Show Menu" style="rectangle" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision" value="Select Option" style="rhombus" vertex="1" parent="1">
          <mxGeometry x="270" y="200" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Options -->
        <mxCell id="add" value="Add Product" style="rectangle" vertex="1" parent="1">
          <mxGeometry x="50" y="350" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="show" value="Show Inventory" style="rectangle" vertex="1" parent="1">
          <mxGeometry x="200" y="350" width="140" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="save" value="Save CSV" style="rectangle" vertex="1" parent="1">
          <mxGeometry x="380" y="350" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="load" value="Load CSV" style="rectangle" vertex="1" parent="1">
          <mxGeometry x="540" y="350" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="exit" value="Exit" style="ellipse" vertex="1" parent="1">
          <mxGeometry x="700" y="350" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell id="e1" edge="1" parent="1" source="start" target="menu"/>
        <mxCell id="e2" edge="1" parent="1" source="menu" target="decision"/>

        <mxCell id="e3" edge="1" parent="1" source="decision" target="add"/>
        <mxCell id="e4" edge="1" parent="1" source="decision" target="show"/>
        <mxCell id="e5" edge="1" parent="1" source="decision" target="save"/>
        <mxCell id="e6" edge="1" parent="1" source="decision" target="load"/>
        <mxCell id="e7" edge="1" parent="1" source="decision" target="exit"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
